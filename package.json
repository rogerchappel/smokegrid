{
  "name": "smokegrid",
  "version": "0.1.0",
  "description": "Fixture-backed CLI smoke test runner for developer tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "smokegrid": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "smoke": "node dist/cli.js run fixtures/smokegrid.self.smoke.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "smoke-test",
    "fixtures",
    "testing",
    "automation"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/smokegrid.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/smokegrid/issues"
  },
  "homepage": "https://github.com/rogerchappel/smokegrid#readme"
}
